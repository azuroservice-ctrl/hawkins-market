# URL serveur du projet Supabase
SUPABASE_URL=https://your-project.supabase.co

# Clé secrète/service_role — serveur uniquement, jamais NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-server-secret

# Identifiants initiaux de la salle de contrôle
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-unique-password

# Secret HMAC indépendant pour signer le cookie administrateur
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters

# URL publique canonique, utilisée par les métadonnées et le sitemap
NEXT_PUBLIC_SITE_URL=https://your-domain.example
